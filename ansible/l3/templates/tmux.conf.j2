# Always use a modern TERM inside tmux (prevents weird mouse/select behavior)
set -g default-terminal "tmux-256color"

# Advertise truecolor to apps when your client is xterm-like
set -as terminal-overrides ",xterm-256color:RGB"
set -as terminal-overrides ",tmux-256color:RGB"

# Enable focus events (harmless; helps some apps)
set -g focus-events on

# Enable mouse support
set -g mouse on

# Change prefix from Ctrl-b to Ctrl-a
set -g prefix C-a
unbind C-b
bind C-a send-prefix

# Vim-style pane navigation (Ctrl-h/j/k/l)
bind -n C-h select-pane -L
bind -n C-j select-pane -D
bind -n C-k select-pane -U
bind -n C-l select-pane -R
