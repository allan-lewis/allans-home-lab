---
services:
  homepage:
    image: ghcr.io/gethomepage/homepage:v1.10.1
    container_name: homepage
    ports:
      - 3007:3000
    volumes:
      - {{ managed_host_volumes['homepage_config'].local }}:/app/config
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      # required, may need port. See gethomepage.dev/installation/#homepage_allowed_hosts
      HOMEPAGE_ALLOWED_HOSTS: homepage.docker.allanshomelab.com,allanshomelab.com
