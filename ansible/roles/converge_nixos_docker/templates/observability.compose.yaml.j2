---
services:

  alertmanager:
    image: prom/alertmanager:latest
    container_name: alertmanager
    restart: unless-stopped
    ports:
      - "3070:9093"
    environment:
      TZ: {{ lab_tz }}
    command:
      - "--config.file=/etc/alertmanager/alertmanager.yml"
      - "--storage.path=/var/lib/alertmanager"
      - "--web.external-url=https://alertmanager.docker.allanshomelab.com"
    volumes:
      - {{ managed_host_volumes['alertmanager_config'].local }}/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro
      - {{ managed_host_volumes['alertmanager_config'].local }}/config:/etc/alertmanager/config:ro
      - {{ managed_host_volumes['alertmanager_data'].local }}:/var/lib/alertmanager

  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    restart: unless-stopped
    ports:
      - "3071:3000"
    env_file:
      - ./.env
    volumes:
      - {{ managed_host_volumes['grafana_data'].local }}:/var/lib/grafana
      - {{ managed_host_volumes['grafana_provision'].local }}:/etc/grafana/provisioning:ro

  prometheus:
    image: prom/prometheus:latest
    container_name: prometheus
    restart: unless-stopped
    ports:
      - "3072:9090"
    user: "{{ lab_uid }}:{{ lab_gid }}"
    command:
      - "--config.file={{ managed_host_volumes['prometheus_config'].local }}/prometheus.yml"
      - "--storage.tsdb.path={{  managed_host_volumes['prometheus_data'].local }}"
      - "--storage.tsdb.retention.time=14d"
      - "--storage.tsdb.retention.size=96GB"
      - "--web.external-url=https://prometheus.docker.allanshomelab.com"
      - "--web.enable-lifecycle"
    volumes:
      - {{ managed_host_volumes['prometheus_config'].local }}/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ managed_host_volumes['prometheus_config'].local }}/rules.yml:/etc/prometheus/rules.yml:ro
      - {{ managed_host_volumes['prometheus_data'].local }}:/var/lib/prometheus
