# Canonical managed directories config rendered from Ansible inventory.
# Source of truth: managed_host_dirs (host_vars/group_vars)

version: 1
generated_at: "{{ ansible_date_time.iso8601 }}"
host: "{{ inventory_hostname }}"

managed_directories:
{% set mhd = managed_host_volumes | default({}) %}
{% if mhd | length == 0 %}
  []
{% else %}
{% for item in (mhd | dict2items | sort(attribute='key')) %}
{% set name = item.key %}
{% set d = item.value %}
{% set t = d.type | default('local') %}
  - name: "{{ name }}"
    type: "{{ t }}"
    local: "{{ d.local }}"
    owner: "{{ d.owner | default('root') }}"
    group: "{{ d.group | default(d.owner | default('root')) }}"
    mode: "{{ d.mode | default('0755') }}"
{# backup/restore: default false for nfs, otherwise default true #}
    backup: {{ (d.backup  | default(false if t == 'nfs' else true)) | bool | lower }}
    restore: {{ (d.restore | default(false if t == 'nfs' else true)) | bool | lower }}
    remote: "{{ d.remote | default('') }}"
    marker: "{{ d.marker | default(managed_dirs_defaults.marker) }}"
    restore_when: "{{ d.restore_when | default(managed_dirs_defaults.restore_when) }}"
    backup_when: "{{ d.backup_when | default(managed_dirs_defaults.backup_when) }}"
    allow_uninitialized_backup: {{ (d.allow_uninitialized_backup | default(managed_dirs_defaults.allow_uninitialized_backup)) | bool | lower }}
{# NFS attributes: only populated when type == nfs, else empty string #}
    server: "{{ (d.server | default('')) if t == 'nfs' else '' }}"
    path: "{{ (d.path   | default('')) if t == 'nfs' else '' }}"
    opts: "{{ (d.opts   | default('ro')) if t == 'nfs' else '' }}"
{% endfor %}
{% endif %}
