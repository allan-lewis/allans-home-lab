{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/allans-home-lab/inventory/host.schema.json",
  "title": "Homelab Host Inventory v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "hostname",
    "platform",
    "variant",
    "role",
    "description",
    "groups",
    "management",
    "runtime",
    "resources",
    "network"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "hostname": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "enum": [
        "nixos",
        "linux",
        "appliance"
      ]
    },
    "variant": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "management": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provisioner",
        "converger"
      ],
      "properties": {
        "provisioner": {
          "type": "string",
          "enum": [
            "terraform",
            "manual",
            "none"
          ]
        },
        "converger": {
          "type": "string",
          "enum": [
            "nixos",
            "ansible",
            "manual",
            "none"
          ]
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "vm",
            "baremetal"
          ]
        },
        "hypervisor": {
          "type": "string",
          "minLength": 1
        },
        "node": {
          "type": "string",
          "minLength": 1
        },
        "vmid": {
          "type": "integer",
          "minimum": 1
        },
        "proxmox": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "disks": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "scsihw",
                "devices",
                "pools"
              ],
              "properties": {
                "scsihw": {
                  "type": "string",
                  "minLength": 1
                },
                "devices": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "slot",
                      "by_id",
                      "opts"
                    ],
                    "properties": {
                      "slot": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "by_id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "opts": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                          "cache": {
                            "type": "string",
                            "minLength": 1
                          },
                          "format": {
                            "type": "string",
                            "minLength": 1
                          },
                          "iothread": {
                            "type": "integer",
                            "minimum": 0
                          }
                        }
                      }
                    }
                  }
                },
                "pools": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "name",
                      "layout",
                      "slots"
                    ],
                    "properties": {
                      "name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "layout": {
                        "type": "string",
                        "minLength": 1
                      },
                      "slots": {
                        "type": "array",
                        "items": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "minItems": 1
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "vm"
              }
            }
          },
          "then": {
            "required": [
              "hypervisor",
              "node"
            ]
          }
        }
      ]
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu",
        "memory_mb",
        "disk_gb"
      ],
      "properties": {
        "cpu": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cores",
            "sockets"
          ],
          "properties": {
            "cores": {
              "type": "integer",
              "minimum": 1
            },
            "sockets": {
              "type": "integer",
              "minimum": 1
            },
            "type": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "memory_mb": {
          "type": "integer",
          "minimum": 128
        },
        "disk_gb": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "static",
            "dhcp",
            "dhcp-reservation"
          ]
        },
        "primary_interface": {
          "type": "string",
          "minLength": 1
        },
        "ipv4": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "address": {
              "type": "string",
              "minLength": 1
            },
            "prefix": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32
            },
            "gateway": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "dns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reservation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ip",
            "mac"
          ],
          "properties": {
            "ip": {
              "type": "string",
              "minLength": 1
            },
            "mac": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "static"
              }
            }
          },
          "then": {
            "required": [
              "ipv4"
            ],
            "properties": {
              "ipv4": {
                "required": [
                  "address",
                  "gateway"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "dhcp-reservation"
              }
            }
          },
          "then": {
            "required": [
              "reservation"
            ]
          }
        }
      ]
    },
    "provisioning": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "terraform": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "datastore": {
              "type": "string",
              "minLength": 1
            },
            "bridge": {
              "type": "string",
              "minLength": 1
            },
            "balloon_mb": {
              "type": "integer",
              "minimum": 0
            },
            "cloud_init": {
              "type": "boolean"
            },
            "agent": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}