services:
  homelab-metrics:
    image: "allanelewis/homelab-metrics:v2026.06.2@sha256:73d7d674df37325dc8347327dc451935ded7a23a6b5070eb46b7ca9ffee349b7"
    container_name: "homelab-metrics"
    restart: "unless-stopped"
    ports: 
      - "9102:9102/tcp"
{% if homelab_metrics_forward_url is defined %}
    environment: 
      FORWARD_METRICS_URL: "{{ homelab_metrics_forward_url }}"
{% endif %}
